{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Network Schema",
  "description": "Schema for normalized Volatility netscan output. Each object represents a single network connection or listening socket.",
  "type": "object",
  "properties": {
    "offset": {
      "type": "string",
      "description": "Memory offset of the network structure"
    },
    "protocol": {
      "type": "string",
      "description": "Network protocol (TCP, UDP, TCPv6, UDPv6)"
    },
    "local_addr": {
      "type": "string",
      "description": "Local IP address"
    },
    "local_port": {
      "type": "integer",
      "description": "Local port number"
    },
    "foreign_addr": {
      "type": "string",
      "description": "Foreign/remote IP address"
    },
    "foreign_port": {
      "type": "integer",
      "description": "Foreign/remote port number"
    },
    "state": {
      "type": "string",
      "description": "Connection state (e.g., ESTABLISHED, LISTENING, CLOSE_WAIT)"
    },
    "pid": {
      "type": "integer",
      "description": "Process ID owning the connection"
    },
    "owner": {
      "type": "string",
      "description": "Process name owning the connection"
    },
    "created": {
      "type": "string",
      "description": "Connection creation timestamp (ISO 8601)"
    }
  },
  "required": ["pid", "protocol"]
}
